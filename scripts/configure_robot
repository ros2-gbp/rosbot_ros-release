import argparse
import os
import re
import sys

import serial
from rosbot_utils.firmware_version import FIRMWARE_VERSION
from rosbot_utils.mcu_manager_ftdi import McuManagerFTDI
from rosbot_utils.mcu_manager_uart import McuManagerUART

RED = "\033[91m"
RESET = "\033[0m"


def print_error(msg: str):
    print(f"{RED}[ERROR] {msg}{RESET}")


VALID_BACKENDS = ("microros", "mavlink")


def configure_robot(
    port: str,
    namespace: str,
    baudrate: int,
    timeout: float = 5.0,
    backend: str = "",
) -> bool:
    if namespace and not re.match(r"^[a-zA-Z0-9_/]+$", namespace):
        print_error(
            f"Invalid namespace: '{namespace}'. Use only alphanumeric characters, underscores and slashes."
        )
        return False
    if backend and backend not in VALID_BACKENDS:
        print_error(f"Invalid backend: '{backend}'. Use one of {VALID_BACKENDS}.")
        return False
    try:
        print(f"Pre-communication with MCU on {port}...")
        serial_port = serial.Serial(port, baudrate, timeout=timeout)
        serial_port.reset_input_buffer()

        raw = serial_port.readline()
        line = raw.decode("utf-8", errors="ignore").replace("\x00", "").strip()

        if line == "":
            print_error("No response.")
            serial_port.close()
            return False

        banner_match = re.match(r"^FW:\s*(\S+)$", line)
        if not banner_match:
            print_error(f"Unexpected response: {repr(line)}")
            serial_port.close()
            return False

        current_fw = banner_match.group(1)
        if not re.fullmatch(rf"FW:\s*{re.escape(FIRMWARE_VERSION)}", line):
            print_error(
                f"Unsupported firmware: {current_fw} Expected: {FIRMWARE_VERSION}. Run: ros2 run rosbot_utils flash_firmware --robot-model <rosbot/rosbot_xl>"
            )
            serial_port.close()
            return False

        print(f"✓ Firmware version detected: {current_fw}")

        # BACKEND: emitted before NS:. No-ACK is fatal — older firmware
        # silently falls out of the handshake on an unknown line.
        if backend:
            serial_port.write(f"BACKEND:{backend}\n".encode("utf-8"))
            serial_port.flush()
            backend_ack = serial_port.readline().decode("utf-8", errors="ignore").strip()
            if backend_ack != "ACK":
                print_error(
                    f"BACKEND configuration failed (got '{backend_ack}'). "
                    f"Firmware likely predates the runtime-switch handshake — "
                    f"flash a build with the BACKEND: parser before running this launch."
                )
                serial_port.close()
                return False
            print(f"✓ Backend selected: {backend}")

        serial_port.write(f"NS:{namespace}\n".encode("utf-8"))
        serial_port.flush()
        ns_ack = serial_port.readline().decode("utf-8", errors="ignore").strip()
        if ns_ack != "ACK":
            print_error(f"Namespace configuration failed. No ACK received: '{ns_ack}'")
            serial_port.close()
            return False
        print(f"✓ Robot configured with namespace: /{namespace}")

        # END closes the pre-comm window without waiting for the
        # firmware's 2.5 s timeout. Older firmware ignores the line —
        # it has already exited the handshake on NS:, so we treat a
        # missing ACK as benign and don't fail the launch.
        serial_port.write(b"END\n")
        serial_port.flush()
        end_ack = serial_port.readline().decode("utf-8", errors="ignore").strip()
        serial_port.close()
        if end_ack == "ACK":
            print("✓ Pre-comm closed via END")
        return True

    except serial.SerialException as e:
        print_error(f"Serial error: {e}")
        return False
    except KeyboardInterrupt:
        print("\nAborted by user.")
        return False


def main(args=None):
    parser = argparse.ArgumentParser(
        description="Configure robot namespace via serial pre-communication."
    )
    _robot_model_env = os.getenv("ROBOT_MODEL_NAME")
    parser.add_argument(
        "--robot-model",
        required=_robot_model_env is None,
        default=_robot_model_env,
        choices=["rosbot", "rosbot_xl"],
        help="Specify the robot model",
    )
    parser.add_argument(
        "--usb", action="store_true", help="Flash via USB. ROSbot XL uses USB by default."
    )
    parser.add_argument("-n", "--namespace", default="", help="Specify the robot namespace")
    parser.add_argument("-b", "--baudrate", type=int, default=921600, help="Serial baudrate")
    parser.add_argument(
        "--backend",
        default="",
        choices=("", *VALID_BACKENDS),
        help="Upstream-link backend to enable on the MCU via the BACKEND: handshake line. "
        "Empty (default) leaves the firmware's own default in place (MICRO_ROS).",
    )
    args = parser.parse_args(args)

    robot_model = args.robot_model
    if robot_model == "rosbot_xl":
        args.usb = True

    try:
        if args.usb:
            port = "/dev/rosbot"
            udev_rules = "/etc/udev/rules.d/99-rosbot.rules"

            if not os.path.exists(port):
                print_error(f"Device {port} not found. Is it connected?")
                sys.exit(1)
            if not os.path.exists(udev_rules):
                print_error(
                    f"No access to device {port}. Install udev rules first:\n  ros2 run rosbot_utils install_udev_rules"
                )
                sys.exit(1)

            mcu_manager = McuManagerFTDI(port)
            mcu_manager.reset_mcu()
            success = configure_robot(
                port,
                args.namespace,
                args.baudrate,
                backend=args.backend,
            )
            sys.exit(0 if success else 1)
        else:
            mcu_manager = McuManagerUART()
            mcu_manager.reset_mcu()
            port = mcu_manager.get_port()
            success = configure_robot(
                port,
                args.namespace,
                args.baudrate,
                backend=args.backend,
            )
            sys.exit(0 if success else 1)

    except Exception as e:
        print_error(str(e))
        sys.exit(1)


if __name__ == "__main__":
    main()
